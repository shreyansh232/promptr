{
  "name": "promptr-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "make -C server dev",
    "dev": "concurrently -n \"web,server\" -c \"cyan,green\" \"pnpm dev:web\" \"pnpm dev:server\"",
    "test:web": "pnpm --filter web test",
    "test:server": "make -C server test",
    "test": "pnpm run test:web && pnpm run test:server",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "lint:server": "make -C server check-lint",
    "lint": "pnpm run lint:web && pnpm run lint:server",
    "format:web": "pnpm --filter web exec prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:server": "make -C server format",
    "format": "pnpm run format:web && pnpm run format:server",
    "clean": "pnpm --filter web clean"
  },
  "packageManager": "pnpm@9.6.0",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
