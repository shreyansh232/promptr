# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

DATABASE_URL=""
AUTH_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
OPENAI_API_KEY=""

# Backend public URL — must match the domain registered in your OAuth app's redirect URI list.
# In production set this to your deployed backend (e.g. https://promptr-backend.railway.app)
# NEXT_PUBLIC_ prefix is required so Next.js includes it in the browser bundle.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# Frontend public URL — used by the backend to redirect users after OAuth login.
FRONTEND_URL="http://localhost:3000"

# Upstash Redis — use rediss:// (double-s) for TLS-enabled connections.
REDIS_URL="rediss://default:<password>@<host>:6379"
